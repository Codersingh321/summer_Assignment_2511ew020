// Write a program to Find largest prime factor

#include <iostream>
using namespace std;
int main() {
    int n;
    int max_prime = -1;

    cout << "Enter an integer: ";
    cin >> n;

    while (n % 2 == 0) {
        max_prime = 2;
        n /= 2;
    }

    for (int i = 3; i * i <= n; i += 2) {
        while (n % i == 0) {
            max_prime = i;
            n /= i;
        }
    }

    if (n > 2) {
        max_prime = n;
    }

    cout << "Largest prime factor: " << max_prime << endl;

    return 0;
}
