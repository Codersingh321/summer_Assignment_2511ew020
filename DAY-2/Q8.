// Write a program to Check whether a number is palindrome

#include <iostream>
using namespace std;
int main() {
    int n;
    int rn = 0;

    cout << "Enter an integer: ";
    cin >> n;

    int original = n;

    while (n > 0) {
        int rem = n % 10;
        rn = rn * 10 + rem;
        n /= 10;
    }

    if (original == rn) {
        cout << original << " is a palindrome." << endl;
    } else {
        cout << original << " is not a palindrome." << endl;
    }

    return 0;
}
