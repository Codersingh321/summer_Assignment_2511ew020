// Write a program to Find product of digits

#include <iostream>
using namespace std;
int main() {
    int n;
    int product = 1;

    cout << "Enter an integer: ";
    cin >> n;

    if (n == 0) {
        product = 0;
    }

    if (n < 0) {
        n = -n;
    }

    while (n > 0) {
        int rem = n % 10;
        product *= rem;
        n /= 10;
    }

    cout << "Product of digits: " << product << endl;

    return 0;
}
