// Write a program to Count set bits in a number

#include <iostream>
using namespace std;
int main() {
    int n;
    int count = 0;

    cout << "Enter an integer: ";
    cin >> n;

    while (n > 0) {
        count += (n & 1);
        n >>= 1;
    }

    cout << "Number of set bits: " << count << endl;

    return 0;
}
