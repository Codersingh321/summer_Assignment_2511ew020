// Write a program to Find x^n without pow()

#include <iostream>
using namespace std;
int main() {
    double x;
    int n;
    double result = 1.0;

    cout << "Enter base (x) and exponent (n): ";
    cin >> x >> n;

    int exp = n;
    if (exp < 0) {
        exp = -exp;
    }

    for (int i = 0; i < exp; i++) {
        result *= x;
    }

    if (n < 0) {
        result = 1.0 / result;
    }

    cout << "Result: " << result << endl;

    return 0;
}
