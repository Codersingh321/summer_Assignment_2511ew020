// Write a program to Convert binary to decimal

#include <iostream>
using namespace std;
int main() {
    long long n;
    int decimal = 0;
    int base = 1;

    cout << "Enter a binary number: ";
    cin >> n;

    long long temp = n;
    while (temp > 0) {
        int rem = temp % 10;
        decimal += rem * base;
        base *= 2;
        temp /= 10;
    }

    cout << "Decimal: " << decimal << endl;

    return 0;
}
