// Write a program to Find LCM of two numbers

#include <iostream>
using namespace std;
int main() {
    int a, b;

    cout << "Enter two numbers: ";
    cin >> a >> b;

    int num1 = a;
    int num2 = b;

    while (num2 != 0) {
        int rem = num1 % num2;
        num1 = num2;
        num2 = rem;
    }

    int gcd = num1;
    int lcm = (a * b) / gcd;

    cout << "LCM: " << lcm << endl;

    return 0;
}
