// Write a program to Count even and odd elements

#include <iostream>
using namespace std;
int main() {
    int size;
    int even_count = 0;
    int odd_count = 0;

    cout << "Enter size of array: ";
    cin >> size;

    int arr[size];

    cout << "Enter elements: ";
    for (int i = 0; i < size; i++) {
        cin >> arr[i];
        if (arr[i] % 2 == 0) {
            even_count++;
        } else {
            odd_count++;
        }
    }

    cout << "Even elements count: " << even_count << endl;
    cout << "Odd elements count: " << odd_count << endl;

    return 0;
}
