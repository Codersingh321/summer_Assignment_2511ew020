// Write a program to Find largest and smallest element

#include <iostream>
using namespace std;
int main() {
    int size;

    cout << "Enter size of array: ";
    cin >> size;

    int arr[size];

    cout << "Enter elements: ";
    for (int i = 0; i < size; i++) {
        cin >> arr[i];
    }

    int max_val = arr[0];
    int min_val = arr[0];

    for (int i = 1; i < size; i++) {
        if (arr[i] > max_val) {
            max_val = arr[i];
        }
        if (arr[i] < min_val) {
            min_val = arr[i];
        }
    }

    cout << "Largest element: " << max_val << endl;
    cout << "Smallest element: " << min_val << endl;

    return 0;
}
