// Write a program to Check Armstrong number

#include <iostream>
#include <cmath>

using namespace std;

int main() {
    int n;
    int sum = 0;
    int digits = 0;

    cout << "Enter an integer: ";
    cin >> n;

    int temp = n;
    while (temp > 0) {
        digits++;
        temp /= 10;
    }

    temp = n;
    while (temp > 0) {
        int rem = temp % 10;
        sum += pow(rem, digits);
        temp /= 10;
    }

    if (sum == n) {
        cout << n << " is an Armstrong number." << endl;
    } else {
        cout << n << " is not an Armstrong number." << endl;
    }

    return 0;
}
