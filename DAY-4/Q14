// Write a program to Find nth Fibonacci term

#include <iostream>
using namespace std;
int main() {
    int n;
    int t1 = 0, t2 = 1, next = 0;

    cout << "Enter the value of n: ";
    cin >> n;

    if (n == 1) {
        cout << "The 1st Fibonacci term is: " << t1 << endl;
        return 0;
    }
    if (n == 2) {
        cout << "The 2nd Fibonacci term is: " << t2 << endl;
        return 0;
    }

    for (int i = 3; i <= n; i++) {
        next = t1 + t2;
        t1 = t2;
        t2 = next;
    }

    cout << "The " << n << "th Fibonacci term is: " << next << endl;

    return 0;
}
