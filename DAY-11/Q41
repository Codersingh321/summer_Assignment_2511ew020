// Write a program to Write function to find sum of two numbers

#include <iostream>
using namespace std;
int find_sum(int a, int b) {
    return a + b;
}

int main() {
    int a, b;

    cout << "Enter two numbers: ";
    cin >> a >> b;

    cout << "Sum: " << find_sum(a, b) << endl;

    return 0;
}
