// Write a program to Write function to find maximum

#include <iostream>
using namespace std;
int find_max(int a, int b) {
    if (a > b) {
        return a;
    }
    return b;
}

int main() {
    int a, b;

    cout << "Enter two numbers: ";
    cin >> a >> b;

    cout << "Maximum: " << find_max(a, b) << endl;

    return 0;
}
