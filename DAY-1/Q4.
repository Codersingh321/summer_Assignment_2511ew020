// Write a program to Count digits in a number

#include <iostream>
using namespace std;
int main() {
    int n;
    cout << "Enter a number: ";
    cin >> n;

    int temp = abs(n);
    int count = 0;

    if (temp == 0) {
        count = 1;
    } else {
        while (temp > 0) {
            temp /= 10;
            count++;
        }
    }
   cout << "Number of digits: " << count << endl;

    return 0;
}
