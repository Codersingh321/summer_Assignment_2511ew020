// Write a program to Second largest element

#include <iostream>
#include <climits>
using namespace std;
int main() {
    int size;

    cout << "Enter size of array: ";
    cin >> size;

    int arr[size];

    cout << "Enter elements: ";
    for (int i = 0; i < size; i++) {
        cin >> arr[i];
    }

    int max_val = INT_MIN;
    int sec_max = INT_MIN;

    for (int i = 0; i < size; i++) {
        if (arr[i] > max_val) {
            sec_max = max_val;
            max_val = arr[i];
        } else if (arr[i] > sec_max && arr[i] != max_val) {
            sec_max = arr[i];
        }
    }

    if (sec_max == INT_MIN) {
        cout << "No second largest element exists." << endl;
    } else {
        cout << "Second largest element: " << sec_max << endl;
    }

    return 0;
}
