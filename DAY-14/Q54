// Write a program to Frequency of an element

#include <iostream>
using namespace std;
int main() {
    int size;
    int target;
    int count = 0;

    cout << "Enter size of array: ";
    cin >> size;

    int arr[size];

    cout << "Enter elements: ";
    for (int i = 0; i < size; i++) {
        cin >> arr[i];
    }

    cout << "Enter element to find frequency: ";
    cin >> target;

    for (int i = 0; i < size; i++) {
        if (arr[i] == target) {
            count++;
        }
    }

    cout << "Frequency of " << target << " is: " << count << endl;

    return 0;
}
