// Write a program to Find duplicates in array

#include <iostream>
using namespace std;
int main() {
    int size;

    cout << "Enter size of array: ";
    cin >> size;

    int arr[size];

    cout << "Enter elements: ";
    for (int i = 0; i < size; i++) {
        cin >> arr[i];
    }

    cout << "Duplicate elements: ";
    for (int i = 0; i < size; i++) {
        bool already_printed = false;
        for (int k = 0; k < i; k++) {
            if (arr[i] == arr[k]) {
                already_printed = true;
                break;
            }
        }
        
        if (already_printed) {
            continue;
        }

        for (int j = i + 1; j < size; j++) {
            if (arr[i] == arr[j]) {
                cout << arr[i] << " ";
                break;
            }
        }
    }
    cout << endl;

    return 0;
}
